    classDef rel fill:#ffffff,stroke:#333,stroke-width:1px
    class rel_0,rel_1,rel_2,rel_3,rel_4,rel_5,rel_6 rel
    classDef legend fill:#fafafa,stroke:#999,stroke-width:1px,stroke-dasharray: 5 5
    class l1,l2,l3,l4,l5,l6,l7 legend